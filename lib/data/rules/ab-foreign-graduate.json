{
  "programId": "ab-foreign-graduate",
  "version": 2,
  "eligibility": [
    {
      "id": "min-clb",
      "label": "Minimum CLB 5 in English or French (all four skills)",
      "condition": {
        "or": [
          { ">=": [{ "var": "clbEnglish" }, 5] },
          { ">=": [{ "var": "clbFrench" }, 5] }
        ]
      },
      "disqualifyMessage": "Language proficiency does not meet the minimum CLB 5 requirement"
    },
    {
      "id": "foreign-degree",
      "label": "Must have a post-secondary credential from outside Canada (within last 10 years)",
      "condition": {
        "and": [
          {
            "or": [
              { "==": [{ "var": "highestEducation" }, "2yr_diploma"] },
              { "==": [{ "var": "highestEducation" }, "3yr_degree"] },
              { "==": [{ "var": "highestEducation" }, "bachelors"] },
              { "==": [{ "var": "highestEducation" }, "masters"] },
              { "==": [{ "var": "highestEducation" }, "phd"] }
            ]
          },
          {
            "or": [
              { "==": [{ "var": "hasCanadianDegree" }, false] },
              { "!": [{ "var": "hasCanadianDegree" }] }
            ]
          }
        ]
      },
      "disqualifyMessage": "Must have a post-secondary credential from an institution outside Canada (ECA required)"
    },
    {
      "id": "min-business-experience",
      "label": "Minimum 6 months business ownership/management experience",
      "condition": {
        ">=": [{ "var": "yearsManagement" }, 0.5]
      },
      "disqualifyMessage": "Must have at least 6 months of business ownership, management, or incubator/accelerator experience"
    },
    {
      "id": "min-investment",
      "label": "Minimum investment: $100,000 (urban) or $50,000 (regional)",
      "condition": {
        ">=": [{ "var": "proposedInvestment" }, 50000]
      },
      "disqualifyMessage": "Must have minimum $50,000 (regional) or $100,000 (urban) investment"
    }
  ],
  "scoring": null
}
