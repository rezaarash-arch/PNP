{
  "programId": "bc-entrepreneur-base",
  "version": 2,
  "eligibility": [
    {
      "id": "min-net-worth",
      "label": "Minimum personal net worth of $600,000 CAD",
      "condition": { ">=": [{ "var": "personalNetWorth" }, 600000] },
      "disqualifyMessage": "Personal net worth ($${personalNetWorth}) is below the $600,000 minimum required"
    },
    {
      "id": "min-clb",
      "label": "Minimum CLB 4 in English or French",
      "condition": {
        "or": [
          { ">=": [{ "var": "clbEnglish" }, 4] },
          { ">=": [{ "var": "clbFrench" }, 4] }
        ]
      },
      "disqualifyMessage": "Language proficiency does not meet the minimum CLB 4 requirement"
    },
    {
      "id": "min-business-exp",
      "label": "Minimum 3 years business ownership or 4 years senior management",
      "condition": {
        "or": [
          { ">=": [{ "var": "businessOwnershipYears" }, 3] },
          { ">=": [{ "var": "seniorManagementYears" }, 4] }
        ]
      },
      "disqualifyMessage": "Does not meet the 3-year ownership or 4-year management minimum"
    },
    {
      "id": "min-investment",
      "label": "Minimum $200,000 CAD personal investment",
      "condition": { ">=": [{ "var": "investmentCapacity" }, 200000] },
      "disqualifyMessage": "Investment capacity ($${investmentCapacity}) is below the $200,000 minimum"
    }
  ],
  "scoring": {
    "maxScore": 200,
    "minScoreRequired": 115,
    "categories": [
      {
        "name": "Experience & Ownership",
        "maxPoints": 24,
        "factors": [
          {
            "name": "Business owner-manager experience (last 10 years)",
            "maxPoints": 20,
            "rules": [
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 5] }, "points": 20, "label": "60+ months ownership" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 4] }, "points": 15, "label": "49-59 months ownership" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 3] }, "points": 12, "label": "37-48 months ownership" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 2] }, "points": 6, "label": "25-36 months ownership" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 1] }, "points": 4, "label": "12-24 months ownership" }
            ]
          },
          {
            "name": "100% ownership bonus",
            "maxPoints": 4,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "businessOwnershipYears" }, 3] }, { ">=": [{ "var": "ownershipPercentage" }, 100] }] }, "points": 4, "label": "100% ownership for 3+ of last 5 years" }
            ]
          }
        ]
      },
      {
        "name": "Personal Net Worth",
        "maxPoints": 12,
        "factors": [
          {
            "name": "Current assets (cash and liquid funds)",
            "maxPoints": 4,
            "rules": [
              { "condition": { ">=": [{ "var": "liquidAssets" }, 400000] }, "points": 4, "label": "$400,000+ current assets" },
              { "condition": { ">=": [{ "var": "liquidAssets" }, 200000] }, "points": 3, "label": "$200K-$400K current assets" },
              { "condition": { ">=": [{ "var": "liquidAssets" }, 50000] }, "points": 2, "label": "$50K-$200K current assets" }
            ]
          },
          {
            "name": "Total personal net worth",
            "maxPoints": 8,
            "rules": [
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 5000000] }, "points": 8, "label": "$5M+ net worth" },
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 2000000] }, "points": 7, "label": "$2M-$5M net worth" },
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 800000] }, "points": 6, "label": "$800K-$2M net worth" },
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 600000] }, "points": 5, "label": "$600K-$800K net worth" }
            ]
          }
        ]
      },
      {
        "name": "Total Personal Investment",
        "maxPoints": 20,
        "factors": [
          {
            "name": "Proposed investment amount",
            "maxPoints": 20,
            "rules": [
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 8000000] }, "points": 20, "label": "$8M+ investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 4000000] }, "points": 16, "label": "$4M-$8M investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 2000000] }, "points": 14, "label": "$2M-$4M investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 1000000] }, "points": 12, "label": "$1M-$2M investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 600000] }, "points": 11, "label": "$600K-$1M investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 400000] }, "points": 10, "label": "$400K-$600K investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 200000] }, "points": 8, "label": "$200K-$400K investment" }
            ]
          }
        ]
      },
      {
        "name": "Job Creation",
        "maxPoints": 12,
        "factors": [
          {
            "name": "Proposed FTE jobs",
            "maxPoints": 12,
            "rules": [
              { "condition": { ">=": [{ "var": "intendedJobCreation" }, 20] }, "points": 12, "label": "20+ FTE jobs" },
              { "condition": { ">=": [{ "var": "intendedJobCreation" }, 10] }, "points": 11, "label": "10-19 FTE jobs" },
              { "condition": { ">=": [{ "var": "intendedJobCreation" }, 7] }, "points": 10, "label": "7-9 FTE jobs" },
              { "condition": { ">=": [{ "var": "intendedJobCreation" }, 5] }, "points": 8, "label": "5 FTE jobs" },
              { "condition": { ">=": [{ "var": "intendedJobCreation" }, 3] }, "points": 6, "label": "3 FTE jobs" },
              { "condition": { ">=": [{ "var": "intendedJobCreation" }, 2] }, "points": 5, "label": "2 FTE jobs" },
              { "condition": { ">=": [{ "var": "intendedJobCreation" }, 1] }, "points": 4, "label": "1 FTE job" }
            ]
          }
        ]
      },
      {
        "name": "B.C. Development Region",
        "maxPoints": 12,
        "factors": [
          {
            "name": "Location of proposed business",
            "maxPoints": 12,
            "rules": [
              { "condition": { "==": [{ "var": "intendedLocation" }, "rural"] }, "points": 12, "label": "Northeast, Kootenay, Nechako, North Coast" },
              { "condition": { "==": [{ "var": "intendedLocation" }, "flexible"] }, "points": 10, "label": "Cariboo" },
              { "condition": { "==": [{ "var": "intendedLocation" }, "regional"] }, "points": 6, "label": "Vancouver Island/Coast, Thompson-Okanagan" },
              { "condition": { "==": [{ "var": "intendedLocation" }, "metro"] }, "points": 0, "label": "Mainland/Southwest (Metro Vancouver)" }
            ]
          }
        ]
      },
      {
        "name": "Adaptability",
        "maxPoints": 40,
        "factors": [
          {
            "name": "Language proficiency",
            "maxPoints": 6,
            "rules": [
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 5] }, { ">=": [{ "var": "clbFrench" }, 5] }] }, "points": 6, "label": "CLB 5+ (Intermediate/Advanced)" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 4] }, { ">=": [{ "var": "clbFrench" }, 4] }] }, "points": 4, "label": "CLB 4 (Basic)" }
            ]
          },
          {
            "name": "Education level",
            "maxPoints": 10,
            "rules": [
              { "condition": { "in": [{ "var": "highestEducation" }, ["masters", "phd"]] }, "points": 10, "label": "Post-graduate / Master's / Doctorate" },
              { "condition": { "in": [{ "var": "highestEducation" }, ["bachelors", "3yr_degree", "2yr_diploma"]] }, "points": 7, "label": "Diploma / Certificate / Bachelor's" },
              { "condition": { "in": [{ "var": "highestEducation" }, ["2yr_diploma", "2yr_diploma"]] }, "points": 4, "label": "Associate degree / Certificate" }
            ]
          },
          {
            "name": "Age",
            "maxPoints": 8,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 35] }, { "<=": [{ "var": "age" }, 44] }] }, "points": 8, "label": "Age 35-44" },
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 45] }, { "<=": [{ "var": "age" }, 54] }] }, "points": 6, "label": "Age 45-54" },
              { "condition": { "or": [{ "and": [{ ">=": [{ "var": "age" }, 25] }, { "<=": [{ "var": "age" }, 34] }] }, { "and": [{ ">=": [{ "var": "age" }, 55] }, { "<=": [{ "var": "age" }, 64] }] }] }, "points": 4, "label": "Age 25-34 or 55-64" }
            ]
          },
          {
            "name": "Exploratory visit to B.C.",
            "maxPoints": 8,
            "rules": [
              { "condition": { "and": [{ "==": [{ "var": "hasExploratoryVisit" }, true] }, { ">=": [{ "var": "exploratoryVisitDays" }, 5] }] }, "points": 8, "label": "Visited target Regional District < 1 year ago" },
              { "condition": { "==": [{ "var": "hasExploratoryVisit" }, true] }, "points": 5, "label": "Visited B.C. < 1 year ago" }
            ]
          },
          {
            "name": "Canadian experience (12+ months work/study)",
            "maxPoints": 8,
            "rules": [
              { "condition": { "or": [{ "==": [{ "var": "hasCanadianWorkExperience" }, true] }, { "==": [{ "var": "hasCanadianDegree" }, true] }] }, "points": 8, "label": "12+ months Canadian work/study experience" }
            ]
          }
        ]
      },
      {
        "name": "Business Concept (assessed by BC PNP)",
        "maxPoints": 80,
        "factors": [
          {
            "name": "Commercial Viability",
            "maxPoints": 30,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "businessOwnershipYears" }, 5] }, { ">=": [{ "var": "investmentCapacity" }, 600000] }] }, "points": 22, "label": "Strong business model, viable investment & market plan" },
              { "condition": { "and": [{ ">=": [{ "var": "businessOwnershipYears" }, 3] }, { ">=": [{ "var": "investmentCapacity" }, 200000] }] }, "points": 16, "label": "Good business model, meets investment requirements" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 200000] }, "points": 10, "label": "Fair business model" }
            ]
          },
          {
            "name": "Transferability of Skills",
            "maxPoints": 15,
            "rules": [
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 5] }, "points": 15, "label": "60+ months direct business experience" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 3] }, "points": 11, "label": "25-36 months direct experience" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 2] }, "points": 9, "label": "13-24 months direct experience" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 1] }, "points": 7, "label": "12 months or less direct experience" }
            ]
          },
          {
            "name": "Economic Benefits",
            "maxPoints": 35,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "intendedJobCreation" }, 5] }, { ">=": [{ "var": "investmentCapacity" }, 800000] }] }, "points": 29, "label": "Key sector + significant benefits + high-skilled jobs" },
              { "condition": { "and": [{ ">=": [{ "var": "intendedJobCreation" }, 2] }, { ">=": [{ "var": "investmentCapacity" }, 400000] }] }, "points": 19, "label": "Key sector or benefit + substantiated jobs plan" },
              { "condition": { ">=": [{ "var": "intendedJobCreation" }, 1] }, "points": 10, "label": "Basic jobs plan with some economic benefit" }
            ]
          }
        ]
      }
    ]
  }
}
