{
  "programId": "mb-entrepreneur",
  "version": 2,
  "eligibility": [
    {
      "id": "min-net-worth",
      "label": "Minimum personal net worth of $500,000 CAD",
      "condition": { ">=": [{ "var": "personalNetWorth" }, 500000] },
      "disqualifyMessage": "Personal net worth ($${personalNetWorth}) is below the $500,000 minimum required"
    },
    {
      "id": "min-clb",
      "label": "Minimum CLB 5 in English or French",
      "condition": {
        "or": [
          { ">=": [{ "var": "clbEnglish" }, 5] },
          { ">=": [{ "var": "clbFrench" }, 5] }
        ]
      },
      "disqualifyMessage": "Language proficiency does not meet the minimum CLB 5 requirement"
    },
    {
      "id": "min-business-exp",
      "label": "Minimum 3 years of business ownership or 5 years senior management experience",
      "condition": {
        "or": [
          { ">=": [{ "var": "businessOwnershipYears" }, 3] },
          { ">=": [{ "var": "seniorManagementYears" }, 5] }
        ]
      },
      "disqualifyMessage": "Business experience does not meet the 3-year ownership or 5-year management minimum"
    },
    {
      "id": "min-investment",
      "label": "Minimum $250,000 CAD personal investment ($150,000 outside Winnipeg)",
      "condition": { ">=": [{ "var": "investmentCapacity" }, 150000] },
      "disqualifyMessage": "Investment capacity ($${investmentCapacity}) is below the minimum required"
    },
    {
      "id": "exploratory-visit",
      "label": "Must have completed a Business Research Visit to Manitoba",
      "condition": { "==": [{ "var": "hasExploratoryVisit" }, true] },
      "disqualifyMessage": "A Business Research Visit to Manitoba is required before applying"
    }
  ],
  "scoring": {
    "maxScore": 150,
    "minScoreRequired": null,
    "categories": [
      {
        "name": "Human Capital",
        "maxPoints": 75,
        "factors": [
          {
            "name": "Age",
            "maxPoints": 10,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 25] }, { "<=": [{ "var": "age" }, 39] }] }, "points": 10, "label": "Age 25-39" },
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 40] }, { "<=": [{ "var": "age" }, 44] }] }, "points": 8, "label": "Age 40-44" },
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 45] }, { "<=": [{ "var": "age" }, 49] }] }, "points": 6, "label": "Age 45-49" },
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 50] }, { "<=": [{ "var": "age" }, 54] }] }, "points": 4, "label": "Age 50-54" },
              { "condition": { "or": [{ "<": [{ "var": "age" }, 25] }, { ">": [{ "var": "age" }, 54] }] }, "points": 0, "label": "Under 25 or over 54" }
            ]
          },
          {
            "name": "Education level",
            "maxPoints": 10,
            "rules": [
              { "condition": { "==": [{ "var": "highestEducation" }, "phd"] }, "points": 10, "label": "Doctorate / PhD" },
              { "condition": { "==": [{ "var": "highestEducation" }, "masters"] }, "points": 9, "label": "Master's degree" },
              { "condition": { "==": [{ "var": "highestEducation" }, "bachelors"] }, "points": 7, "label": "Bachelor's degree" },
              { "condition": { "in": [{ "var": "highestEducation" }, ["3yr_degree", "2yr_diploma"]] }, "points": 5, "label": "3-year diploma or trade certificate" },
              { "condition": { "==": [{ "var": "highestEducation" }, "2yr_diploma"] }, "points": 3, "label": "2-year diploma" },
              { "condition": { "==": [{ "var": "highestEducation" }, "2yr_diploma"] }, "points": 2, "label": "1-year certificate" },
              { "condition": { "==": [{ "var": "highestEducation" }, "high_school"] }, "points": 0, "label": "High school or less" }
            ]
          },
          {
            "name": "Business experience",
            "maxPoints": 30,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "businessOwnershipYears" }, 5] }, { ">=": [{ "var": "ownershipPercentage" }, 51] }] }, "points": 30, "label": "5+ years as majority owner-operator" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 5] }, "points": 25, "label": "5+ years business ownership" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 4] }, "points": 20, "label": "4 years business ownership" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 3] }, "points": 15, "label": "3 years business ownership" },
              { "condition": { ">=": [{ "var": "seniorManagementYears" }, 5] }, "points": 10, "label": "5+ years senior management" },
              { "condition": { ">=": [{ "var": "seniorManagementYears" }, 3] }, "points": 5, "label": "3-4 years senior management" }
            ]
          },
          {
            "name": "Language proficiency (English or French)",
            "maxPoints": 25,
            "rules": [
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 9] }, { ">=": [{ "var": "clbFrench" }, 9] }] }, "points": 25, "label": "CLB 9+ (Advanced)" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 8] }, { ">=": [{ "var": "clbFrench" }, 8] }] }, "points": 22, "label": "CLB 8" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 7] }, { ">=": [{ "var": "clbFrench" }, 7] }] }, "points": 18, "label": "CLB 7" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 6] }, { ">=": [{ "var": "clbFrench" }, 6] }] }, "points": 14, "label": "CLB 6" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 5] }, { ">=": [{ "var": "clbFrench" }, 5] }] }, "points": 10, "label": "CLB 5" }
            ]
          }
        ]
      },
      {
        "name": "Investment",
        "maxPoints": 50,
        "factors": [
          {
            "name": "Personal net worth",
            "maxPoints": 10,
            "rules": [
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 2000000] }, "points": 10, "label": "$2M+ net worth" },
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 1000000] }, "points": 7, "label": "$1M-$2M net worth" },
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 500000] }, "points": 4, "label": "$500K-$1M net worth" }
            ]
          },
          {
            "name": "Business investment amount",
            "maxPoints": 15,
            "rules": [
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 1000000] }, "points": 15, "label": "$1M+ investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 500000] }, "points": 12, "label": "$500K-$1M investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 350000] }, "points": 9, "label": "$350K-$500K investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 250000] }, "points": 6, "label": "$250K-$350K investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 150000] }, "points": 3, "label": "$150K-$250K investment" }
            ]
          },
          {
            "name": "Business Research Visit to Manitoba",
            "maxPoints": 20,
            "rules": [
              { "condition": { "and": [{ "==": [{ "var": "hasExploratoryVisit" }, true] }, { ">=": [{ "var": "exploratoryVisitDays" }, 7] }] }, "points": 20, "label": "7+ day research visit" },
              { "condition": { "and": [{ "==": [{ "var": "hasExploratoryVisit" }, true] }, { ">=": [{ "var": "exploratoryVisitDays" }, 5] }] }, "points": 15, "label": "5-6 day research visit" },
              { "condition": { "and": [{ "==": [{ "var": "hasExploratoryVisit" }, true] }, { ">=": [{ "var": "exploratoryVisitDays" }, 3] }] }, "points": 10, "label": "3-4 day research visit" },
              { "condition": { "==": [{ "var": "hasExploratoryVisit" }, true] }, "points": 5, "label": "Short research visit" }
            ]
          },
          {
            "name": "Economic priorities alignment",
            "maxPoints": 5,
            "rules": [
              { "condition": { "==": [{ "var": "intendedLocation" }, "rural"] }, "points": 5, "label": "Rural Manitoba priority sector" },
              { "condition": { "==": [{ "var": "intendedLocation" }, "regional"] }, "points": 3, "label": "Regional Manitoba" },
              { "condition": { "==": [{ "var": "intendedLocation" }, "metro"] }, "points": 1, "label": "Winnipeg metro" }
            ]
          }
        ]
      },
      {
        "name": "Adaptability",
        "maxPoints": 25,
        "factors": [
          {
            "name": "Spouse/common-law partner language proficiency",
            "maxPoints": 5,
            "rules": [
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 7] }, { ">=": [{ "var": "clbFrench" }, 7] }] }, "points": 5, "label": "Spouse CLB 7+ in English or French" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 5] }, { ">=": [{ "var": "clbFrench" }, 5] }] }, "points": 3, "label": "Spouse CLB 5-6 in English or French" }
            ]
          },
          {
            "name": "Spouse/common-law partner second language",
            "maxPoints": 5,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "clbEnglish" }, 5] }, { ">=": [{ "var": "clbFrench" }, 5] }] }, "points": 5, "label": "Bilingual (CLB 5+ in both English and French)" },
              { "condition": { ">=": [{ "var": "clbFrench" }, 5] }, "points": 3, "label": "French CLB 5+ as second language" }
            ]
          },
          {
            "name": "Close relative in Manitoba",
            "maxPoints": 5,
            "rules": [
              { "condition": { "==": [{ "var": "hasFamilyInCanada" }, true] }, "points": 5, "label": "Has close relative in Manitoba" },
              { "condition": { "==": [{ "var": "hasFamilyInCanada" }, false] }, "points": 0, "label": "No close relative in Manitoba" }
            ]
          },
          {
            "name": "Child enrolled in Manitoba school",
            "maxPoints": 5,
            "rules": [
              { "condition": { "==": [{ "var": "hasFamilyInCanada" }, true] }, "points": 5, "label": "Child attending school in Manitoba" },
              { "condition": { "==": [{ "var": "hasFamilyInCanada" }, false] }, "points": 0, "label": "No child in Manitoba school" }
            ]
          },
          {
            "name": "Spouse education or employment in Manitoba",
            "maxPoints": 5,
            "rules": [
              { "condition": { "==": [{ "var": "hasCanadianWorkExperience" }, true] }, "points": 5, "label": "Spouse has education or employment in Manitoba" },
              { "condition": { "==": [{ "var": "hasCanadianWorkExperience" }, false] }, "points": 0, "label": "No spouse education/employment in Manitoba" }
            ]
          }
        ]
      }
    ]
  }
}
