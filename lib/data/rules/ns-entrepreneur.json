{
  "programId": "ns-entrepreneur",
  "version": 2,
  "eligibility": [
    {
      "id": "min-net-worth",
      "label": "Minimum personal net worth of $600,000 CAD",
      "condition": { ">=": [{ "var": "personalNetWorth" }, 600000] },
      "disqualifyMessage": "Personal net worth ($${personalNetWorth}) is below the $600,000 minimum required"
    },
    {
      "id": "min-clb",
      "label": "Minimum CLB 5 in English or French",
      "condition": {
        "or": [
          { ">=": [{ "var": "clbEnglish" }, 5] },
          { ">=": [{ "var": "clbFrench" }, 5] }
        ]
      },
      "disqualifyMessage": "Language proficiency does not meet the minimum CLB 5 requirement"
    },
    {
      "id": "min-business-exp",
      "label": "Minimum 3 years of business ownership or 5 years senior management experience",
      "condition": {
        "or": [
          { ">=": [{ "var": "businessOwnershipYears" }, 3] },
          { ">=": [{ "var": "seniorManagementYears" }, 5] }
        ]
      },
      "disqualifyMessage": "Business experience does not meet the 3-year ownership or 5-year management minimum"
    },
    {
      "id": "min-investment",
      "label": "Minimum $150,000 CAD personal investment",
      "condition": { ">=": [{ "var": "investmentCapacity" }, 150000] },
      "disqualifyMessage": "Investment capacity ($${investmentCapacity}) is below the $150,000 minimum"
    }
  ],
  "scoring": {
    "maxScore": 150,
    "minScoreRequired": null,
    "categories": [
      {
        "name": "Language Proficiency",
        "maxPoints": 35,
        "factors": [
          {
            "name": "Primary language (English or French)",
            "maxPoints": 28,
            "rules": [
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 7] }, { ">=": [{ "var": "clbFrench" }, 7] }] }, "points": 28, "label": "CLB 7+" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 6] }, { ">=": [{ "var": "clbFrench" }, 6] }] }, "points": 24, "label": "CLB 6" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 5] }, { ">=": [{ "var": "clbFrench" }, 5] }] }, "points": 20, "label": "CLB 5" }
            ]
          },
          {
            "name": "Second official language proficiency",
            "maxPoints": 7,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "clbEnglish" }, 5] }, { ">=": [{ "var": "clbFrench" }, 5] }] }, "points": 7, "label": "CLB 5+ in second official language" }
            ]
          }
        ]
      },
      {
        "name": "Education",
        "maxPoints": 25,
        "factors": [
          {
            "name": "Highest education level",
            "maxPoints": 25,
            "rules": [
              { "condition": { "==": [{ "var": "highestEducation" }, "phd"] }, "points": 25, "label": "Doctorate / PhD" },
              { "condition": { "==": [{ "var": "highestEducation" }, "masters"] }, "points": 23, "label": "Master's degree" },
              { "condition": { "in": [{ "var": "highestEducation" }, ["bachelors", "3yr_degree"]] }, "points": 21, "label": "Bachelor's or 3-year diploma" },
              { "condition": { "in": [{ "var": "highestEducation" }, ["2yr_diploma", "2yr_diploma"]] }, "points": 19, "label": "2-year diploma or trade certificate" },
              { "condition": { "==": [{ "var": "highestEducation" }, "2yr_diploma"] }, "points": 12, "label": "1-year certificate" },
              { "condition": { "==": [{ "var": "highestEducation" }, "high_school"] }, "points": 8, "label": "High school diploma" }
            ]
          }
        ]
      },
      {
        "name": "Business Experience",
        "maxPoints": 35,
        "factors": [
          {
            "name": "Business ownership or management experience",
            "maxPoints": 35,
            "rules": [
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 5] }, "points": 35, "label": "5+ years business ownership" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 3] }, "points": 20, "label": "3-5 years business ownership" },
              { "condition": { ">=": [{ "var": "seniorManagementYears" }, 5] }, "points": 20, "label": "5+ years senior management" }
            ]
          }
        ]
      },
      {
        "name": "Net Worth",
        "maxPoints": 10,
        "factors": [
          {
            "name": "Total personal net worth",
            "maxPoints": 10,
            "rules": [
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 1500000] }, "points": 10, "label": "$1.5M+ net worth" },
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 1000000] }, "points": 7, "label": "$1M-$1.5M net worth" },
              { "condition": { ">=": [{ "var": "personalNetWorth" }, 600000] }, "points": 5, "label": "$600K-$999K net worth" }
            ]
          }
        ]
      },
      {
        "name": "Age",
        "maxPoints": 10,
        "factors": [
          {
            "name": "Age range",
            "maxPoints": 10,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 33] }, { "<=": [{ "var": "age" }, 39] }] }, "points": 10, "label": "Age 33-39" },
              { "condition": { "or": [{ "and": [{ ">=": [{ "var": "age" }, 25] }, { "<=": [{ "var": "age" }, 32] }] }, { "and": [{ ">=": [{ "var": "age" }, 40] }, { "<=": [{ "var": "age" }, 44] }] }] }, "points": 7, "label": "Age 25-32 or 40-44" },
              { "condition": { "or": [{ "and": [{ ">=": [{ "var": "age" }, 21] }, { "<=": [{ "var": "age" }, 24] }] }, { "and": [{ ">=": [{ "var": "age" }, 45] }, { "<=": [{ "var": "age" }, 55] }] }] }, "points": 5, "label": "Age 21-24 or 45-55" },
              { "condition": { "or": [{ "<": [{ "var": "age" }, 21] }, { ">": [{ "var": "age" }, 55] }] }, "points": 0, "label": "Under 21 or over 55" }
            ]
          }
        ]
      },
      {
        "name": "Adaptability",
        "maxPoints": 10,
        "factors": [
          {
            "name": "Exploratory visit and connections",
            "maxPoints": 10,
            "rules": [
              { "condition": { "and": [{ "==": [{ "var": "hasExploratoryVisit" }, true] }, { "==": [{ "var": "hasFamilyInCanada" }, true] }] }, "points": 10, "label": "Exploratory visit and family in NS" },
              { "condition": { "and": [{ "==": [{ "var": "hasExploratoryVisit" }, true] }, { ">=": [{ "var": "exploratoryVisitDays" }, 5] }] }, "points": 7, "label": "5+ day exploratory visit" },
              { "condition": { "==": [{ "var": "hasExploratoryVisit" }, true] }, "points": 5, "label": "Exploratory visit" },
              { "condition": { "==": [{ "var": "hasFamilyInCanada" }, true] }, "points": 3, "label": "Family in Nova Scotia" }
            ]
          }
        ]
      },
      {
        "name": "Nova Scotia Economic Priorities",
        "maxPoints": 10,
        "factors": [
          {
            "name": "Export-oriented business",
            "maxPoints": 5,
            "rules": [
              { "condition": { ">=": [{ "var": "annualRevenue" }, 500000] }, "points": 5, "label": "Export-oriented business with significant revenue" },
              { "condition": { ">=": [{ "var": "annualRevenue" }, 100000] }, "points": 3, "label": "Some export potential" }
            ]
          },
          {
            "name": "Location outside Halifax Regional Municipality",
            "maxPoints": 5,
            "rules": [
              { "condition": { "!=": [{ "var": "intendedLocation" }, "metro"] }, "points": 5, "label": "Business outside Halifax" },
              { "condition": { "==": [{ "var": "intendedLocation" }, "metro"] }, "points": 0, "label": "Business in Halifax" }
            ]
          }
        ]
      },
      {
        "name": "Investment",
        "maxPoints": 15,
        "factors": [
          {
            "name": "Personal investment amount",
            "maxPoints": 15,
            "rules": [
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 300000] }, "points": 15, "label": "$300K+ investment" },
              { "condition": { ">=": [{ "var": "investmentCapacity" }, 150000] }, "points": 10, "label": "$150K-$300K investment" }
            ]
          }
        ]
      }
    ]
  }
}
