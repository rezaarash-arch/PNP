{
  "programId": "pei-work-permit",
  "version": 2,
  "eligibility": [
    {
      "id": "min-net-worth",
      "label": "Minimum personal net worth of $600,000 CAD",
      "condition": { ">=": [{ "var": "personalNetWorth" }, 600000] },
      "disqualifyMessage": "Personal net worth ($${personalNetWorth}) is below the $600,000 minimum required"
    },
    {
      "id": "min-clb",
      "label": "Minimum CLB 4 in English or French",
      "condition": {
        "or": [
          { ">=": [{ "var": "clbEnglish" }, 4] },
          { ">=": [{ "var": "clbFrench" }, 4] }
        ]
      },
      "disqualifyMessage": "Language proficiency does not meet the minimum CLB 4 requirement"
    },
    {
      "id": "min-business-exp",
      "label": "Minimum 3 years of business ownership or 5 years senior management experience",
      "condition": {
        "or": [
          { ">=": [{ "var": "businessOwnershipYears" }, 3] },
          { ">=": [{ "var": "seniorManagementYears" }, 5] }
        ]
      },
      "disqualifyMessage": "Business experience does not meet the 3-year ownership or 5-year management minimum"
    },
    {
      "id": "min-investment",
      "label": "Minimum $150,000 CAD personal investment",
      "condition": { ">=": [{ "var": "investmentCapacity" }, 150000] },
      "disqualifyMessage": "Investment capacity ($${investmentCapacity}) is below the $150,000 minimum"
    },
    {
      "id": "community-endorsement",
      "label": "Must have a community endorsement",
      "condition": { "==": [{ "var": "hasCommunityReferral" }, true] },
      "disqualifyMessage": "A community endorsement from a PEI community is required"
    }
  ],
  "scoring": {
    "maxScore": 200,
    "minScoreRequired": null,
    "categories": [
      {
        "name": "Age",
        "maxPoints": 20,
        "factors": [
          {
            "name": "Age range",
            "maxPoints": 20,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 25] }, { "<=": [{ "var": "age" }, 44] }] }, "points": 20, "label": "Age 25-44" },
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 45] }, { "<=": [{ "var": "age" }, 49] }] }, "points": 15, "label": "Age 45-49" },
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 50] }, { "<=": [{ "var": "age" }, 54] }] }, "points": 10, "label": "Age 50-54" },
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 21] }, { "<=": [{ "var": "age" }, 24] }] }, "points": 8, "label": "Age 21-24" },
              { "condition": { "and": [{ ">=": [{ "var": "age" }, 55] }, { "<=": [{ "var": "age" }, 59] }] }, "points": 5, "label": "Age 55-59" },
              { "condition": { "or": [{ "<": [{ "var": "age" }, 21] }, { ">": [{ "var": "age" }, 59] }] }, "points": 0, "label": "Under 21 or over 59" }
            ]
          }
        ]
      },
      {
        "name": "Language Proficiency",
        "maxPoints": 40,
        "factors": [
          {
            "name": "English or French language proficiency",
            "maxPoints": 40,
            "rules": [
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 9] }, { ">=": [{ "var": "clbFrench" }, 9] }] }, "points": 40, "label": "CLB 9-10" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 7] }, { ">=": [{ "var": "clbFrench" }, 7] }] }, "points": 30, "label": "CLB 7-8" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 5] }, { ">=": [{ "var": "clbFrench" }, 5] }] }, "points": 15, "label": "CLB 5-6" },
              { "condition": { "or": [{ ">=": [{ "var": "clbEnglish" }, 4] }, { ">=": [{ "var": "clbFrench" }, 4] }] }, "points": 0, "label": "CLB 4 (minimum)" }
            ]
          }
        ]
      },
      {
        "name": "Education",
        "maxPoints": 20,
        "factors": [
          {
            "name": "Highest education level",
            "maxPoints": 20,
            "rules": [
              { "condition": { "in": [{ "var": "highestEducation" }, ["masters", "phd"]] }, "points": 20, "label": "Master's or Doctorate" },
              { "condition": { "==": [{ "var": "highestEducation" }, "bachelors"] }, "points": 17, "label": "Bachelor's degree" },
              { "condition": { "in": [{ "var": "highestEducation" }, ["3yr_degree", "2yr_diploma"]] }, "points": 12, "label": "Trade certificate or 3-year diploma" },
              { "condition": { "==": [{ "var": "highestEducation" }, "2yr_diploma"] }, "points": 8, "label": "2-year diploma" },
              { "condition": { "==": [{ "var": "highestEducation" }, "2yr_diploma"] }, "points": 5, "label": "1-year certificate" },
              { "condition": { "==": [{ "var": "highestEducation" }, "high_school"] }, "points": 0, "label": "High school or less" }
            ]
          }
        ]
      },
      {
        "name": "Business Experience",
        "maxPoints": 50,
        "factors": [
          {
            "name": "Business ownership and management experience",
            "maxPoints": 50,
            "rules": [
              { "condition": { "and": [{ ">=": [{ "var": "businessOwnershipYears" }, 5] }, { ">": [{ "var": "ownershipPercentage" }, 50] }] }, "points": 50, "label": "5+ years with >50% ownership" },
              { "condition": { "and": [{ ">=": [{ "var": "businessOwnershipYears" }, 3] }, { ">": [{ "var": "ownershipPercentage" }, 50] }] }, "points": 35, "label": "3-5 years with >50% ownership" },
              { "condition": { ">=": [{ "var": "seniorManagementYears" }, 5] }, "points": 30, "label": "5+ years senior management" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 5] }, "points": 25, "label": "5+ years ownership (minority stake)" },
              { "condition": { ">=": [{ "var": "seniorManagementYears" }, 3] }, "points": 20, "label": "3-5 years senior management" },
              { "condition": { ">=": [{ "var": "businessOwnershipYears" }, 3] }, "points": 15, "label": "3-5 years ownership (minority stake)" }
            ]
          }
        ]
      },
      {
        "name": "Community Endorsement",
        "maxPoints": 35,
        "factors": [
          {
            "name": "Community endorsement type",
            "maxPoints": 35,
            "rules": [
              { "condition": { "and": [{ "==": [{ "var": "hasCommunityReferral" }, true] }, { "==": [{ "var": "intendedLocation" }, "rural"] }] }, "points": 35, "label": "Rural community endorsement" },
              { "condition": { "and": [{ "==": [{ "var": "hasCommunityReferral" }, true] }, { "==": [{ "var": "intendedLocation" }, "regional"] }] }, "points": 25, "label": "Regional community endorsement" },
              { "condition": { "and": [{ "==": [{ "var": "hasCommunityReferral" }, true] }, { "==": [{ "var": "intendedLocation" }, "flexible"] }] }, "points": 18, "label": "Flexible location endorsement" },
              { "condition": { "==": [{ "var": "hasCommunityReferral" }, true] }, "points": 10, "label": "Capital region endorsement" },
              { "condition": { "==": [{ "var": "hasCommunityReferral" }, false] }, "points": 0, "label": "No community endorsement" }
            ]
          }
        ]
      },
      {
        "name": "Adaptability",
        "maxPoints": 35,
        "factors": [
          {
            "name": "Children enrolled in PEI school",
            "maxPoints": 10,
            "rules": [
              { "condition": { "==": [{ "var": "hasFamilyInCanada" }, true] }, "points": 10, "label": "Children attending school in PEI" },
              { "condition": { "==": [{ "var": "hasFamilyInCanada" }, false] }, "points": 0, "label": "No children in PEI schools" }
            ]
          },
          {
            "name": "Spouse/partner education",
            "maxPoints": 5,
            "rules": [
              { "condition": { "==": [{ "var": "hasCanadianDegree" }, true] }, "points": 5, "label": "Spouse has post-secondary education" },
              { "condition": { "==": [{ "var": "hasCanadianDegree" }, false] }, "points": 0, "label": "No spouse post-secondary" }
            ]
          },
          {
            "name": "Close family members in PEI",
            "maxPoints": 10,
            "rules": [
              { "condition": { "==": [{ "var": "hasFamilyInCanada" }, true] }, "points": 10, "label": "Has close family in PEI" },
              { "condition": { "==": [{ "var": "hasFamilyInCanada" }, false] }, "points": 0, "label": "No close family in PEI" }
            ]
          },
          {
            "name": "Canadian work or study experience",
            "maxPoints": 10,
            "rules": [
              { "condition": { "and": [{ "==": [{ "var": "hasCanadianWorkExperience" }, true] }, { "==": [{ "var": "hasCanadianDegree" }, true] }] }, "points": 10, "label": "Canadian work and study experience" },
              { "condition": { "==": [{ "var": "hasCanadianWorkExperience" }, true] }, "points": 7, "label": "Canadian work experience" },
              { "condition": { "==": [{ "var": "hasCanadianDegree" }, true] }, "points": 5, "label": "Canadian study experience" }
            ]
          }
        ]
      }
    ]
  }
}
